# Claude iMessage Daemon Configuration
# Copy this file to ~/.claude-imessage.env and customize

# REQUIRED: Contact to monitor
IMESSAGE_CONTACT_PHONE="4155551234"       # Phone number (digits only, no + or -)
IMESSAGE_CONTACT_NAME="John Doe"          # Display name of the contact

# OPTIONAL: Additional contact identifiers
IMESSAGE_CONTACT_EMAIL="john@example.com" # If they use email for iMessage

# OPTIONAL: Daemon behavior
IMESSAGE_CHECK_INTERVAL="1"               # How often to check for messages (seconds)
IMESSAGE_TMP_DIR="$HOME/tmp/imessage"    # Where to store logs and state

# USAGE:
# 1. Copy this file: cp examples/.env.example ~/.claude-imessage.env
# 2. Edit with your values: nano ~/.claude-imessage.env
# 3. Source before running daemon: source ~/.claude-imessage.env
# 4. Start daemon: nohup ~/Developer/claude-imessage/daemon/imessage-auto-reply-daemon.sh &
